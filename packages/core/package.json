{
  "name": "@presenter/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/browser.ts",
      "default": "./src/browser.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "default": "./src/node.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "chardet": "^2.1.0",
    "ffprobe-static": "^3.1.0",
    "image-size": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
